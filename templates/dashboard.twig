{% extends 'layout.twig' %}

{% block title %}Configuration TTS{% endblock %}

{% block content %}
    <section class="page-title">
        <div>
            <h1>Configuration TTS</h1>
            <p>Connecté en tant que <strong>{{ user.display_name }}</strong>.</p>
        </div>
        {% if user.profile_image_url %}
            <img class="avatar" src="{{ user.profile_image_url }}" alt="Avatar Twitch de {{ user.display_name }}">
        {% endif %}
    </section>

    {% if flash %}
        <div class="flash">{{ flash }}</div>
    {% endif %}

    <section class="panel">
        <h2>URL overlay OBS</h2>
        <p>Ajoute cette URL comme source navigateur dans OBS :</p>
        <div class="copy-row">
            <input id="overlay-url" type="text" readonly value="{{ overlayUrl }}" data-base-overlay-url="{{ overlayUrl|e('html_attr') }}">
            <button type="button" data-copy-target="overlay-url">Copier</button>
        </div>
        <label class="inline-checkbox">
            <input id="overlay-show-chat" type="checkbox" data-overlay-chat-toggle>
            Afficher le chat dans l’overlay
        </label>
        <small>Cette option ajoute <code>show_chat=1</code> à l’URL OBS. Décoche-la pour garder seulement l’audio TTS.</small>
        <p class="warning-message">Attention : l’audio du TTS ne fonctionne pas si l’option OBS « Control audio via OBS » est activée sur la source navigateur suite à un bug chromium.</p>
    </section>

    <details class="panel dashboard-tts-panel" data-dashboard-tts-panel>
        <summary class="collapsible-panel-header">
            <div>
                <h2>Lecture du chat en TTS</h2>
                <p>Ouvre ce cadre pour connecter le chat Twitch et lire les messages depuis cette page.</p>
            </div>
            <span class="collapsible-panel-indicator" aria-hidden="true"></span>
        </summary>
        <div class="dashboard-tts-frame-wrapper" hidden data-dashboard-tts-content>
            <iframe
                title="Overlay TTS Twitch intégré"
                data-dashboard-tts-frame
                data-src="{{ overlayUrl|e('html_attr') }}"
                allow="autoplay"
            ></iframe>
            <small>Quand ce cadre est fermé, l’overlay est déchargé et le chat n’est plus lu.</small>
        </div>
    </details>

    <form class="settings-form panel" method="post" action="/dashboard/settings">
        <input type="hidden" name="_csrf_token" value="{{ csrfToken }}">
        <h2>Préférences</h2>

        <label>
            Chaîne Twitch
            <input name="channel" type="text" required pattern="[#]?[a-zA-Z0-9_]{4,25}" value="{{ settings.channel }}">
        </label>

        <label>
            Volume
            <span class="range-field">
                <input name="volume" type="range" min="0" max="1" step="0.1" value="{{ settings.volume }}" data-range-output="volume-value">
                <output id="volume-value">{{ settings.volume }}</output>
            </span>
        </label>

        <label>
            Vitesse de lecture
            <span class="range-field">
                <input name="rate" type="range" min="0.5" max="2" step="0.1" value="{{ settings.rate ?? 1 }}" data-range-output="rate-value">
                <output id="rate-value">{{ settings.rate ?? 1 }}</output>
            </span>
            <small>1 = vitesse normale, 0.5 = plus lent, 2 = plus rapide.</small>
        </label>

        <label>
            Voix préférée
            <select id="voice-select" name="voice_name" data-selected-voice="{{ (settings.voice_name ?? '')|e('html_attr') }}">
                <option value="">Voix par défaut du navigateur</option>
            </select>
            <small>La liste dépend du navigateur/OBS qui ouvre cette page. Si la voix n’existe pas côté overlay, la voix par défaut sera utilisée.</small>
        </label>

        <div class="tts-test-field">
            <label>
                Tester le TTS
                <textarea id="tts-test-message" rows="3">Ceci est un test de lecture Twitch TTS.</textarea>
            </label>
            <button type="button" data-tts-test>Lire le test</button>
            <small id="tts-test-status" aria-live="polite">Le test utilise la voix, le volume et la vitesse actuellement sélectionnés dans ce navigateur.</small>
        </div>

        <div class="checkbox-grid">
            <label><input name="announce_chatter" type="checkbox" value="1" {% if settings.announce_chatter %}checked{% endif %}> Annoncer le pseudo</label>
            <label><input name="mods_only" type="checkbox" value="1" {% if settings.mods_only %}checked{% endif %}> Restreindre aux modérateurs</label>
            <label><input name="vips_only" type="checkbox" value="1" {% if settings.vips_only %}checked{% endif %}> Restreindre aux VIPs</label>
            <label><input name="tagged_only" type="checkbox" value="1" {% if settings.tagged_only %}checked{% endif %}> Messages mentionnant le streamer</label>
            <label><input name="ignore_replies" type="checkbox" value="1" {% if settings.ignore_replies %}checked{% endif %}> Ignorer les réponses à un message</label>
            <label><input name="ignore_known_bots" type="checkbox" value="1" {% if settings.ignore_known_bots %}checked{% endif %}> Ignorer les comptes chatbot Twitch (ex: WizeBot)</label>
            <label><input name="ignore_emotes" type="checkbox" value="1" {% if settings.ignore_emotes %}checked{% endif %}> Ignorer les emotes dans la lecture TTS</label>
            <label><input name="exclude_commands" type="checkbox" value="1" {% if settings.exclude_commands %}checked{% endif %}> Ignorer les commandes <code>!</code></label>
            <label><input name="exclude_links" type="checkbox" value="1" {% if settings.exclude_links %}checked{% endif %}> Ignorer les liens</label>
        </div>
        <small>Si une restriction de rôle est activée, les autres spectateurs sont ignorés. Tu peux combiner modérateurs et VIPs ; le broadcaster reste toujours autorisé.</small>

        <label>
            Chatters exclus, un par ligne
            <textarea name="excluded_chatters" rows="6">{{ excludedChattersText }}</textarea>
        </label>

        <div class="form-grid">
            <label>
                Longueur max des messages
                <input name="max_message_length" type="number" min="1" max="500" value="{{ settings.max_message_length }}">
            </label>
            <label>
                Cooldown entre lectures, en ms
                <input name="cooldown_ms" type="number" min="0" max="30000" step="100" value="{{ settings.cooldown_ms }}">
            </label>
        </div>

        <button class="button primary" type="submit">Sauvegarder</button>
    </form>
{% endblock %}

{% block scripts %}
    <script src="/assets/dashboard.js?v={{ appVersion|url_encode }}"></script>
{% endblock %}