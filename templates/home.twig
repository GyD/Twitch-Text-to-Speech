{% extends 'layout.twig' %}

{% block title %}Twitch TTS - Accueil{% endblock %}

{% block content %}
    <section class="hero">
        <h1>TTS natif pour chat twitch.</h1>
        <p>
            Connecte ton compte Twitch, configure tes préférences TTS puis ajoute l’URL d’overlay dans OBS.
        </p>

        {% if isAuthenticated %}
            <a class="button primary" href="/dashboard">Ouvrir la configuration</a>
        {% else %}
            <a class="button primary" href="/login">Se connecter avec Twitch</a>
        {% endif %}
    </section>
{% endblock %}